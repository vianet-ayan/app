{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["src"],
  "exclude": ["frontend", "node_modules", "dist"]
}
